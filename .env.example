# ============================================================
# BioPC — R Programming for Biologists landing page
# Copy this file to `.env.local` and fill in real values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# --- Site ---
# Full public URL of the deployed site (used for SEO, OG tags, canonical).
NEXT_PUBLIC_SITE_URL=https://courses.biopc.org

# --- Meta (Facebook) Pixel ---
# Your Pixel ID from Meta Events Manager. Leave empty to disable.
NEXT_PUBLIC_META_PIXEL_ID=

# --- Google Analytics 4 (optional) ---
# Measurement ID, e.g. G-XXXXXXXXXX. Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Registration storage (Google Sheets via Apps Script) ---
# The Web App URL you get after deploying google-apps-script/Code.gs.
# This is used server-side only (safe, not exposed to the browser).
SHEETS_WEBAPP_URL=

# A shared secret. Set the SAME value in the Apps Script (SHARED_SECRET)
# so only your site can write to the sheet.
SHEETS_SHARED_SECRET=change-me-to-a-long-random-string
